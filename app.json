{
  "expo": {
    "name": "BossBook",
    "slug": "OK",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app_logo/boss-book-logo.png",
    "scheme": "bossbook",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./app_logo/boss-book-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kader95.BossBook"
    },
    "web": {
      "output": "static",
      "favicon": "./app_logo/boss-book-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./app_logo/boss-book-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "API_URL": "http://192.168.0.102:4000",
      "router": {},
      "eas": {
        "projectId": "43075f4f-5720-40cc-ab0f-3cee21a98217"
      }
    }
  }
}



